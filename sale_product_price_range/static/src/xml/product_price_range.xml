<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-inherit="sale.Product" t-inherit-mode="extension">
        <xpath expr="//t[@t-foreach='this.props.attribute_lines']" position="attributes">
            <attribute name="t-foreach">filteredAttributeLines</attribute>
        </xpath>
        <xpath expr="//div[@name='o_sale_product_configurator_name']" position="after">
            <div
                t-if="showSalePriceRangeInConfigurator"
                class="border rounded p-2 mt-2 mb-3 small"
            >
                <div class="text-muted text-uppercase fw-semibold mb-1">Allowed Range</div>
                <div class="fw-semibold mb-2" t-out="formattedAllowedSalePriceRange"/>
                <div class="d-flex flex-wrap align-items-center gap-2">
                    <span class="text-muted">Current Price</span>
                    <span
                        class="badge rounded-pill"
                        t-att-class="{
                            'text-bg-success': salePriceRangeStatus === 'in_range',
                            'text-bg-warning': salePriceRangeStatus === 'below_min',
                            'text-bg-danger': salePriceRangeStatus === 'above_max',
                        }"
                        t-out="salePriceRangeStatusLabel"
                    />
                </div>
            </div>
        </xpath>
    </t>

    <t t-inherit="sale.ProductConfiguratorDialog" t-inherit-mode="extension">
        <xpath expr="//ProductList[1]" position="before">
            <div t-if="showVariantSearch" class="mb-3">
                <label class="form-label fw-semibold mb-1">Search Variant</label>
                <div class="input-group">
                    <input
                        class="form-control"
                        type="text"
                        placeholder="Search variant value"
                        autocomplete="off"
                        spellcheck="false"
                        t-att-value="variantSearchQuery"
                        t-on-input="onVariantSearchInput"
                    />
                    <button
                        t-if="variantSearchQuery"
                        class="btn btn-outline-secondary"
                        type="button"
                        t-on-click="clearVariantSearch"
                    >
                        Clear
                    </button>
                </div>
                <div t-if="variantSearchSuggestions.length" class="list-group mt-2 shadow-sm">
                    <button
                        t-foreach="variantSearchSuggestions"
                        t-as="suggestion"
                        t-key="suggestion.key"
                        type="button"
                        class="list-group-item list-group-item-action d-flex justify-content-between align-items-start gap-2"
                        t-on-click="onVariantSearchSuggestionClick.bind(this, suggestion)"
                    >
                        <span class="flex-grow-1 min-w-0 text-start">
                            <span class="d-block fw-semibold text-truncate" t-out="suggestion.attributeValueName"/>
                            <span
                                t-if="suggestion.secondaryLabel"
                                class="d-block text-muted small text-truncate"
                                t-out="suggestion.secondaryLabel"
                            />
                        </span>
                        <span
                            t-if="suggestion.isSelected"
                            class="badge text-bg-success align-self-center"
                        >
                            Selected
                        </span>
                        <span
                            t-elif="suggestion.isOptional"
                            class="badge text-bg-light border align-self-center"
                        >
                            Optional
                        </span>
                    </button>
                </div>
                <div t-elif="variantSearchQuery" class="text-muted small mt-1">
                    No matching variant values found.
                </div>
                <div class="text-muted small mt-1">
                    Type a variant value to filter the options, then pick a matching choice below.
                </div>
            </div>
        </xpath>
    </t>
</templates>
